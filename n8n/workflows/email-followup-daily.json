{
  "name": "Email Follow-up Queue (Daily)",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 9 * * *" }] }
      },
      "id": "cron-daily",
      "name": "Cron: Daily 09:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/outbound/process-queue"
      },
      "id": "process-queue",
      "name": "API: Process Follow-ups",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://api:8000/outbound/stats"
      },
      "id": "get-stats",
      "name": "API: Outbound Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 300]
    }
  ],
  "connections": {
    "Cron: Daily 09:00": { "main": [[{ "node": "API: Process Follow-ups", "type": "main", "index": 0 }]] },
    "API: Process Follow-ups": { "main": [[{ "node": "API: Outbound Stats", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "agentur" }, { "name": "lean" }]
}
