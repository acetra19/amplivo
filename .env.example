# Database
POSTGRES_USER=agentur
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=agentur

# VPS / Public URLs – amplivo.net
API_DOMAIN=api.amplivo.net
LANDING_DOMAIN=www.amplivo.net
DASHBOARD_DOMAIN=dash.amplivo.net
N8N_HOST=n8n.amplivo.net
N8N_WEBHOOK_URL=https://n8n.amplivo.net
CADDY_ADMIN_EMAIL=admin@amplivo.net
CORS_ORIGINS=*

# n8n
N8N_DB_NAME=n8n
N8N_ENCRYPTION_KEY=generate-a-random-32-character-key
TZ=Europe/Berlin

# LLM – Groq recommended (free tier). Configure also via Dashboard → Settings
LLM_PROVIDER=groq
GROQ_API_KEY=
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile
CLASSIFIER_MODEL=llama-3.1-8b-instant

# Email – Brevo (configure via Dashboard → Settings)
BREVO_API_KEY=
OUTBOUND_FROM_EMAIL=sales@amplivo.net
OUTBOUND_FROM_NAME="Amplivo Sales Team"
DAILY_EMAIL_LIMIT=30

# Affiliate Tracking
AFFILIATE_PRODUCT_SLUG=gohighlevel
AFFILIATE_TRACKING_BASE=
AFFILIATE_POSTBACK_SECRET=change-me-postback-secret

# Agent Settings
ICP_INDUSTRY=marketing_agency
ICP_MIN_EMPLOYEES=2
ICP_MAX_EMPLOYEES=50
LEAD_SCORE_THRESHOLD=70
